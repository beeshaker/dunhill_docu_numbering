<odoo>
    <record id="view_document_reference_company_list" model="ir.ui.view">
        <field name="name">document.reference.company.list</field>
        <field name="model">document.reference.company</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_document_reference_company" model="ir.actions.act_window">
        <field name="name">Companies</field>
        <field name="res_model">document.reference.company</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_document_reference_department_list" model="ir.ui.view">
        <field name="name">document.reference.department.list</field>
        <field name="model">document.reference.department</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_document_reference_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">document.reference.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_document_reference_type_list" model="ir.ui.view">
        <field name="name">document.reference.type.list</field>
        <field name="model">document.reference.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_document_reference_type" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">document.reference.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_document_reference_property_list" model="ir.ui.view">
        <field name="name">document.reference.property.list</field>
        <field name="model">document.reference.property</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="category"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_document_reference_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">document.reference.property</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_document_reference_sequence_list" model="ir.ui.view">
        <field name="name">document.reference.sequence.list</field>
        <field name="model">document.reference.sequence</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="company_id"/>
                <field name="department_id"/>
                <field name="year"/>
                <field name="next_number"/>
            </list>
        </field>
    </record>

    <record id="action_document_reference_sequence" model="ir.actions.act_window">
        <field name="name">Reference Sequences</field>
        <field name="res_model">document.reference.sequence</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
